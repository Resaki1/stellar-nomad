--- a/build/three.webgpu.js
+++ b/build/three.webgpu.js
@@ -72157,9 +72157,32 @@ class WebGPUTextureUtils {
 
 		} else if ( texture.isArrayTexture || texture.isDataArrayTexture || texture.isData3DTexture ) {
 
-			for ( let i = 0; i < options.image.depth; i ++ ) {
+			if ( texture.isData3DTexture && mipmaps.length > 0 ) {
 
-				this._copyBufferToTexture( options.image, textureData.texture, textureDescriptorGPU, i, texture.flipY, i );
+				// Manually authored 3D mip chain (mipmaps[ 0 ] is the base level),
+				// mirroring the isDataTexture path above. Mip level i of a 3D
+				// texture has max( 1, depth >> i ) slices, uploaded one at a time.
+
+				for ( let i = 0, il = mipmaps.length; i < il; i ++ ) {
+
+					const mipmap = mipmaps[ i ];
+					const mipDepth = mipmap.depth !== undefined ? mipmap.depth : Math.max( 1, options.image.depth >> i );
+
+					for ( let j = 0; j < mipDepth; j ++ ) {
+
+						this._copyBufferToTexture( mipmap, textureData.texture, textureDescriptorGPU, j, texture.flipY, j, i );
+
+					}
+
+				}
+
+			} else {
+
+				for ( let i = 0; i < options.image.depth; i ++ ) {
+
+					this._copyBufferToTexture( options.image, textureData.texture, textureDescriptorGPU, i, texture.flipY, i );
+
+				}
 
 			}
 
